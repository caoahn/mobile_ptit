# FastAPI Configuration
APP_NAME=YOLO Detection API
APP_VERSION=1.0.0
DEBUG=True

# YOLO Model Configuration
MODEL_PATH=models/yolo11n.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# VLM Configuration
VLM_MODEL_NAME=openai/clip-vit-base-patch32
VLM_ALPHA=0.6

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=yolo_detection_queue
REDIS_JOB_TIMEOUT=300

# Queue Configuration
MAX_WORKERS=2
JOB_TIMEOUT=180

# Directory Configuration
UPLOAD_DIR=uploads
TEMP_DIR=temp
LOGS_DIR=logs

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".bmp"]

# Logging
LOG_LEVEL=INFO

# postgreSQL Configuration
POSTGRES_URL=postgresql://user:password@localhost/dbname
